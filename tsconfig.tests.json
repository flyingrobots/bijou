{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "include": ["packages/*/src/**/*.test.ts", "packages/*/src/**/*.d.ts", "scripts/**/*.test.ts", "scripts/**/*.d.ts"]
}
