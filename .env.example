# Locale selection (process env locale heuristics, used by node locale ports)
# LANG
# LANGUAGE
# LC_ALL
# LC_MESSAGES

# Explicit locale override for i18n examples and local development.
# BIJOU_LOCALE=en

# Pick a preset theme by id or a path to a DTCG JSON theme.
# BIJOU_THEME=teal-orange-pink

# Disable color globally (no-color convention).
# NO_COLOR=1

# Force screen-reader-friendly output.
# BIJOU_ACCESSIBLE=1

# Override terminal refresh detection for animations.
# BIJOU_FPS=60

# Skip PTY smoke tests in non-TTY/dev environments.
# BIJOU_SKIP_PTY_TESTS=1

# Keep temporary canary workspace after canary smoke run (debugging aid).
# BIJOU_KEEP_CANARY_TMP=1
